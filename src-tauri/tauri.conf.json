{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenMicroChat",
  "version": "1.0.0",
  "identifier": "com.nightpoetry.openmicrochat",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "bash scripts/build-frontend.sh",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "OpenMicroChat",
        "width": 960,
        "height": 680,
        "minWidth": 360,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
